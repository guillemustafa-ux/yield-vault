# Copiá este archivo como `.env` y completá los valores.
# El .env NUNCA se sube a git (está en .gitignore).

# URL del RPC de cada red. Sacá una gratis en Alchemy (alchemy.com) o Infura.
# Ejemplo Alchemy: https://eth-sepolia.g.alchemy.com/v2/TU_API_KEY
SEPOLIA_RPC_URL=
# L2 testnets (Prioridad 1 del plan). Alchemy soporta ambas con una sola cuenta.
BASE_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=

# API key de Etherscan (etherscan.io/myapikey). Con Etherscan API V2 esta misma
# key verifica en Sepolia, Base Sepolia y Arbitrum Sepolia (se enruta por chainid).
ETHERSCAN_API_KEY=

# (Opcional) Parámetros del pase al desplegar. Si no los ponés, usa los defaults
# del script: 0.001 ETH por período, 30 días.
# BOTPASS_PRICE=1000000000000000
# BOTPASS_PERIOD=2592000
# BOTPASS_BASE_URI=ipfs://

# Clave privada de la wallet que despliega.
# ⚠️ USÁ UNA WALLET DE PRUEBA, descartable, SIN fondos reales. Solo ETH de faucet.
# ⚠️ NUNCA pongas acá la clave de una wallet con plata de verdad.
PRIVATE_KEY=
